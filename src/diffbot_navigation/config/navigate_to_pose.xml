<root BTCPP_format="4">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="6" name="NavigateRecovery">
      <PipelineSequence name="NavigateWithReplanning">
        <RateController hz="1.0">
          <Action ID="ComputePathToPose" goal="{goal}" path="{path}" planner_id="GridBased"/>
        </RateController>
        <Action ID="FollowPath" path="{path}" controller_id="FollowPath"/>
      </PipelineSequence>
      <Fallback name="RecoveryActions">
        <Action ID="ClearEntireCostmap" name="ClearGlobalCostmap-Sub" service_name="global_costmap/clear_entirely_global_costmap"/>
        <Action ID="Spin" spin_dist="1.57"/>
        <Action ID="Wait" wait_duration="5"/>
      </Fallback>
    </RecoveryNode>
  </BehaviorTree>
</root>